# Copy this file to `.env` and fill in your own values

# ==============================
# DISCORD
# ==============================
DISCORD_TOKEN=your_discord_bot_token_here
BOT_PREFIX=wov
MILESTONE_CHANNEL_ID=123456789012345678
BIRTHDAY_CHANNEL_ID=123456789012345678
BOT_CHANNEL_ID=123456789012345678

# ==============================
# WOLVESVILLE API
# ==============================
WOLVESVILLE_API_KEY=your_wolvesville_api_key_here
CLAN_ID=clan_id_here

# ==============================
# DATABASE
# ==============================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
DB_NAME=wov_db